{
  "name": "my-movies",
  "version": "1.0.0",
  "description": "MERN Movies App with DevOps CI/CD scaffolding",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "backend": "nodemon backend/index.js",
    "frontend": "npm run dev --prefix frontend",
    "fullstack": "concurrently \"npm run backend\" \"npm run frontend\"",
    "seed": "node backend/seeder.js",
    "setup": "npm ci && npm ci --prefix frontend",
    "setup:seed": "npm run setup && npm run seed",
    "start:full": "npm run setup:seed && npm run fullstack",
    "lint:backend": "eslint backend --ext .js",
    "lint:frontend": "npm run lint --prefix frontend",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:backend": "cross-env NODE_ENV=test jest --runInBand --config jest.config.cjs",
    "test": "npm run test:backend",
    "build:frontend": "npm run build --prefix frontend",
    "docker:build:backend": "docker build -f Dockerfile.backend -t mern-movies-backend:latest .",
    "docker:build:frontend": "docker build -f Dockerfile.frontend -t mern-movies-frontend:latest .",
    "docker:build": "npm run docker:build:backend && npm run docker:build:frontend",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^8.1.1",
    "multer": "^1.4.5-lts.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "babel-jest": "^29.6.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "supertest": "^6.3.4",
    "vite": "^8.0.16"
  }
}
